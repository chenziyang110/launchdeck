{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://launchdeck.dev/schema/launchdeck.schema.json",
  "title": "Launchdeck Configuration",
  "type": "object",
  "required": ["version", "tasks"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tasks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "$ref": "#/$defs/task"
          }
        ]
      }
    },
    "clean": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "safe": {
          "$ref": "#/$defs/cleanList"
        },
        "risky": {
          "$ref": "#/$defs/cleanList"
        }
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "cwd": {
          "type": "string",
          "default": "."
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "longRunning": {
          "type": "boolean",
          "default": false
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "uniqueItems": true,
          "default": []
        },
        "risk": {
          "type": "string",
          "enum": ["low", "medium", "high", "destructive"],
          "default": "medium"
        },
        "log": {
          "type": "string"
        }
      }
    },
    "cleanList": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": ["path"],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              }
            }
          }
        ]
      },
      "default": []
    }
  }
}
