{
  "name": "launchdeck",
  "version": "0.1.0",
  "description": "Universal lifecycle control for local software projects.",
  "keywords": [
    "cli",
    "developer-tools",
    "lifecycle",
    "process-manager"
  ],
  "homepage": "https://github.com/chenziyang110/launchdeck#readme",
  "bugs": {
    "url": "https://github.com/chenziyang110/launchdeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenziyang110/launchdeck.git"
  },
  "type": "module",
  "bin": {
    "launchdeck": "./src/cli.js",
    "launchdeck-mcp": "./src/mcp/stdio-server.js"
  },
  "files": [
    "src/",
    "schema/",
    "agent/compatibility-manifest.json",
    ".agents/skills/launchdeck-agent/"
  ],
  "scripts": {
    "check": "node scripts/check-syntax.js",
    "test": "node --test --test-concurrency=1",
    "test:e2e": "node scripts/run-e2e-tests.js",
    "agent:build": "node scripts/build-agent-plugins.js",
    "smoke": "node scripts/smoke-lifecycle.js --mode quick --json",
    "package:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "semver": "7.8.5",
    "yaml": "^2.5.1",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "chenziyang110",
  "devDependencies": {
    "esbuild": "0.28.1"
  }
}
