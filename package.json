{
  "name": "launchdeck",
  "version": "0.1.0",
  "description": "Universal lifecycle control for local software projects.",
  "keywords": [
    "cli",
    "developer-tools",
    "lifecycle",
    "process-manager"
  ],
  "homepage": "https://github.com/chenziyang110/launchdeck#readme",
  "bugs": {
    "url": "https://github.com/chenziyang110/launchdeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenziyang110/launchdeck.git"
  },
  "type": "module",
  "bin": {
    "launchdeck": "./src/cli.js"
  },
  "files": [
    "src/",
    "schema/",
    ".agents/skills/launchdeck-agent/"
  ],
  "scripts": {
